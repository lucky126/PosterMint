{
  "id": "store-promo",
  "name": "店铺宣传海报",
  "scene": "store_promo",
  "description": "店铺照片、简介、特色卖点和联系方式。",
  "canvas": {
    "width": 1080,
    "height": 1920,
    "background": "#18231f"
  },
  "fields": [
    { "key": "storeImage", "label": "店铺照片", "type": "image", "required": true },
    { "key": "storeName", "label": "店铺名称", "type": "text", "required": true, "maxLength": 18 },
    { "key": "headline", "label": "宣传标题", "type": "text", "maxLength": 22, "default": "地道好味，现炒现做" },
    { "key": "description", "label": "店铺简介", "type": "text", "maxLength": 70, "default": "主打本地人常来的家常风味，适合朋友聚会、家庭用餐和日常外卖。" },
    { "key": "features", "label": "特色卖点", "type": "features", "default": ["招牌菜", "朋友聚餐", "外卖自取"] },
    { "key": "address", "label": "地址", "type": "text", "maxLength": 32 },
    { "key": "phone", "label": "电话", "type": "text", "maxLength": 18 },
    { "key": "qrcode", "label": "二维码", "type": "qrcode" }
  ],
  "layout": [
    { "type": "rect", "x": 0, "y": 0, "w": 1080, "h": 1920, "fill": "#18231f" },
    { "type": "image", "field": "storeImage", "x": 0, "y": 0, "w": 1080, "h": 620, "fit": "cover", "placeholder": "店铺照片" },
    { "type": "rect", "x": 0, "y": 620, "w": 1080, "h": 310, "fill": "#14231e" },
    { "type": "text", "field": "storeName", "x": 82, "y": 682, "w": 916, "h": 96, "fontSize": 72, "fontWeight": 900, "color": "#fff6df", "maxLines": 1 },
    { "type": "text", "field": "headline", "x": 86, "y": 802, "w": 880, "h": 104, "fontSize": 34, "fontWeight": 700, "lineHeight": 1.25, "color": "#cfe2a3", "maxLines": 2 },
    { "type": "rect", "x": 70, "y": 990, "w": 940, "h": 450, "radius": 22, "fill": "#fff8e9" },
    { "type": "text", "text": "门店简介", "x": 106, "y": 1038, "w": 300, "h": 48, "fontSize": 34, "fontWeight": 900, "color": "#1f392e", "maxLines": 1 },
    { "type": "text", "field": "description", "x": 106, "y": 1114, "w": 868, "h": 156, "fontSize": 32, "fontWeight": 500, "lineHeight": 1.35, "color": "#3a2c22", "maxLines": 3 },
    {
      "type": "repeat",
      "field": "features",
      "x": 106,
      "y": 1310,
      "w": 760,
      "h": 80,
      "columns": 3,
      "gapX": 16,
      "itemHeight": 54,
      "maxItems": 3,
      "children": [
        { "type": "rect", "x": 0, "y": 0, "w": 232, "h": 54, "radius": 27, "fill": "#1f6b4c" },
        { "type": "text", "field": "$value", "x": 12, "y": 10, "w": 208, "h": 36, "fontSize": 24, "fontWeight": 800, "color": "#fff8e9", "align": "center", "maxLines": 1 }
      ]
    },
    { "type": "rect", "x": 70, "y": 1500, "w": 940, "h": 330, "radius": 22, "fill": "#263b34" },
    { "type": "text", "field": "address", "x": 112, "y": 1554, "w": 620, "h": 56, "fontSize": 30, "fontWeight": 700, "color": "#fff6df", "maxLines": 1 },
    { "type": "text", "field": "phone", "x": 112, "y": 1630, "w": 480, "h": 50, "fontSize": 30, "fontWeight": 700, "color": "#cfe2a3", "maxLines": 1 },
    { "type": "text", "text": "扫码了解更多", "x": 110, "y": 1724, "w": 360, "h": 48, "fontSize": 30, "fontWeight": 800, "color": "#fff6df", "maxLines": 1 },
    { "type": "qrcode", "field": "qrcode", "x": 790, "y": 1578, "w": 170, "h": 170, "radius": 8, "fit": "contain", "placeholder": "二维码" }
  ]
}
