{
  "id": "menu-grid",
  "name": "十菜电子菜单",
  "scene": "menu",
  "description": "适合 6 到 10 个菜品，图片和价格成组展示。",
  "canvas": {
    "width": 1080,
    "height": 1920,
    "background": "#f7efe0"
  },
  "fields": [
    {
      "key": "storeName",
      "label": "店铺名称",
      "type": "text",
      "maxLength": 16,
      "default": "本店菜单"
    },
    {
      "key": "title",
      "label": "菜单标题",
      "type": "text",
      "maxLength": 12,
      "default": "招牌菜单"
    },
    {
      "key": "subtitle",
      "label": "副标题",
      "type": "text",
      "maxLength": 22,
      "default": "现点现做 · 人气推荐"
    },
    {
      "key": "items",
      "label": "菜品列表",
      "type": "items",
      "required": true
    },
    {
      "key": "qrcode",
      "label": "二维码",
      "type": "qrcode"
    }
  ],
  "layout": [
    {
      "type": "rect",
      "x": 0,
      "y": 0,
      "w": 1080,
      "h": 1920,
      "fill": "#f7efe0"
    },
    {
      "type": "rect",
      "x": 64,
      "y": 68,
      "w": 952,
      "h": 150,
      "radius": 20,
      "fill": "#214f3d"
    },
    {
      "type": "text",
      "field": "storeName",
      "x": 96,
      "y": 92,
      "w": 340,
      "h": 42,
      "fontSize": 30,
      "fontWeight": 700,
      "color": "#f7efe0",
      "maxLines": 1
    },
    {
      "type": "text",
      "field": "title",
      "x": 96,
      "y": 132,
      "w": 620,
      "h": 78,
      "fontSize": 58,
      "fontWeight": 900,
      "color": "#fff9e8",
      "maxLines": 1
    },
    {
      "type": "text",
      "field": "subtitle",
      "x": 608,
      "y": 146,
      "w": 360,
      "h": 48,
      "fontSize": 28,
      "fontWeight": 600,
      "color": "#d8e2b4",
      "align": "right",
      "maxLines": 1
    },
    {
      "type": "repeat",
      "field": "items",
      "x": 64,
      "y": 272,
      "w": 952,
      "h": 1360,
      "columns": 2,
      "gapX": 28,
      "gapY": 26,
      "itemHeight": 248,
      "maxItems": 10,
      "children": [
        {
          "type": "rect",
          "x": 0,
          "y": 0,
          "w": 462,
          "h": 248,
          "radius": 18,
          "fill": "#fffaf0",
          "stroke": "#ead7b5",
          "strokeWidth": 2
        },
        {
          "type": "image",
          "field": "image",
          "x": 18,
          "y": 18,
          "w": 180,
          "h": 180,
          "radius": 14,
          "fit": "cover",
          "placeholder": "菜品图"
        },
        {
          "type": "text",
          "field": "name",
          "x": 222,
          "y": 42,
          "w": 210,
          "h": 86,
          "fontSize": 36,
          "fontWeight": 800,
          "color": "#291811",
          "maxLines": 2
        },
        {
          "type": "price",
          "field": "price",
          "x": 222,
          "y": 150,
          "w": 190,
          "h": 56,
          "fontSize": 42,
          "fontWeight": 900,
          "color": "#b22b20",
          "maxLines": 1
        },
        {
          "type": "text",
          "text": "推荐",
          "x": 24,
          "y": 206,
          "w": 92,
          "h": 32,
          "fontSize": 22,
          "fontWeight": 700,
          "color": "#214f3d",
          "maxLines": 1
        }
      ]
    },
    {
      "type": "rect",
      "x": 64,
      "y": 1684,
      "w": 952,
      "h": 150,
      "radius": 18,
      "fill": "#fffaf0",
      "stroke": "#ead7b5",
      "strokeWidth": 2
    },
    {
      "type": "text",
      "text": "扫码查看完整菜单1",
      "x": 100,
      "y": 1730,
      "w": 520,
      "h": 54,
      "fontSize": 38,
      "fontWeight": 800,
      "color": "#214f3d",
      "maxLines": 1
    },
    {
      "type": "text",
      "text": "价格以门店实际活动为准",
      "x": 102,
      "y": 1784,
      "w": 500,
      "h": 38,
      "fontSize": 24,
      "fontWeight": 500,
      "color": "#826749",
      "maxLines": 1
    },
    {
      "type": "qrcode",
      "field": "qrcode",
      "x": 820,
      "y": 1710,
      "w": 104,
      "h": 104,
      "radius": 6,
      "fit": "contain",
      "placeholder": "二维码"
    }
  ]
}