<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="PosterMint.Web.styles.css" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
    <script>
        // 海报预览缩放：读取模板真实画布尺寸(data-w/data-h)，按父容器可用空间宽/高取小者等比缩放。
        // 支持任意画布比例（竖版 9:16、方图 1:1、横版 16:9、长图 1:3 等）。
        // 用 ResizeObserver 保证首帧和窗口大小变化都能触发。
        (function () {
            function scaleOne(box) {
                var canvas = box.querySelector('.poster-canvas');
                if (!canvas) return;

                var baseW = parseFloat(canvas.getAttribute('data-w')) || 1080;
                var baseH = parseFloat(canvas.getAttribute('data-h')) || 1920;

                // stage 是 poster-scale 的父容器，用它的可用空间作为约束
                var stage = box.parentElement;
                if (!stage) return;
                var stageStyle = getComputedStyle(stage);
                var padX = parseFloat(stageStyle.paddingLeft) + parseFloat(stageStyle.paddingRight);
                var padY = parseFloat(stageStyle.paddingTop) + parseFloat(stageStyle.paddingBottom);
                var maxW = stage.clientWidth - padX;
                var maxH = stage.clientHeight - padY;
                if (maxW <= 0 || maxH <= 0) return;

                // 等比缩放：宽高约束取更严的那个
                var scale = Math.min(maxW / baseW, maxH / baseH);
                var w = baseW * scale;
                var h = baseH * scale;

                // 让 poster-scale 精准贴合缩放后的画布尺寸，避免出现空白边或超边界
                box.style.width = w + 'px';
                box.style.height = h + 'px';

                canvas.style.transformOrigin = 'top left';
                canvas.style.transform = 'scale(' + scale + ')';
            }

            var ro = window.ResizeObserver ? new ResizeObserver(function (entries) {
                entries.forEach(function (e) {
                    // 变化的是 stage，找它里面的 poster-scale
                    var box = e.target.querySelector ? e.target.querySelector('.poster-scale') : null;
                    if (box) scaleOne(box);
                });
            }) : null;

            window.fitPoster = function () {
                document.querySelectorAll('.poster-scale').forEach(function (box) {
                    var stage = box.parentElement;
                    if (ro && stage && !stage.__observed) { ro.observe(stage); stage.__observed = true; }
                    scaleOne(box);
                });
            };

            window.addEventListener('resize', function () { window.fitPoster(); });
        })();
    </script>
</body>

</html>
