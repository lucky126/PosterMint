@page "/shop/templates"
@using PosterMint.Application.AI
@using PosterMint.Application.Templates
@using PosterMint.Application.Sessions
@inject ITemplateService TemplateService
@inject ISessionService SessionService
@inject IChatEditingAiService AiService
@inject NavigationManager NavigationManager

<PageTitle>模板广场（后备路径）</PageTitle>

<section class="hero gallery-hero">
    <p class="eyebrow">Fallback Path</p>
    <h1>这是后备入口，不是主入口</h1>
    <p class="summary">
        主路径已经改成“场景 + 参考图 + 对话”的模式。这里保留模板广场，只作为降级入口或调试入口。
        当前对话引擎：<strong>@(AiService.GetStatus().Mode == "external" ? "外部模型" : "本地对话引擎")</strong>。
    </p>
</section>

@if (_loading)
{
    <p>正在加载模板…</p>
}
else
{
    <section class="template-grid">
        @foreach (var template in _templates)
        {
            <article class="template-card">
                <div class="template-card__meta">
                    <span class="scene-pill">@GetSceneText(template.Scene)</span>
                    <span class="status-pill">@template.Status</span>
                </div>
                <h2>@template.Name</h2>
                <p>@template.Description</p>
                <div class="tag-row">
                    @foreach (var tag in template.Tags.Take(3))
                    {
                        <span class="tag-chip">@tag.TagValue</span>
                    }
                </div>
                <button class="action-button" @onclick="() => StartAsync(template)">开始制作</button>
            </article>
        }
    </section>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <p class="error-text">@_error</p>
}

@code {
    private IReadOnlyList<TemplateSummaryDto> _templates = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _templates = await TemplateService.ListAsync();
        }
        catch (Exception exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task StartAsync(TemplateSummaryDto template)
    {
        var session = await SessionService.CreateAsync(new CreateSessionRequest
        {
            TemplateId = template.Id,
            Name = $"{template.Name} 演示会话"
        });

        NavigationManager.NavigateTo($"/shop/sessions/{session.SessionKey}");
    }

    private static string GetSceneText(PosterMint.Domain.Enums.TemplateSceneType scene) =>
        scene switch
        {
            PosterMint.Domain.Enums.TemplateSceneType.SingleDish => "单菜品",
            PosterMint.Domain.Enums.TemplateSceneType.Menu => "菜单",
            PosterMint.Domain.Enums.TemplateSceneType.StorePromo => "店铺宣传",
            PosterMint.Domain.Enums.TemplateSceneType.Festival => "节庆",
            _ => "自定义"
        };
}
