@page "/admin/categories"
@using PosterMint.Application.Templates
@inject ITemplateService TemplateService

<PageTitle>后台分类</PageTitle>

<section class="hero admin-hero">
    <p class="eyebrow">Mall Console</p>
    <h1>模板分类是商场模板生产的起点</h1>
    <p class="summary">
        这里不是普通的栏目管理，而是模板生产策略面板。分类决定模板在商场端如何生产，
        也决定商铺端如何被推荐、审核和分发。
    </p>
</section>

@if (_loading)
{
    <p>正在加载分类摘要…</p>
}
else
{
    <section class="category-grid">
        @foreach (var category in _categories)
        {
            <article class="category-card">
                <div class="category-card__top">
                    <div>
                        <span class="eyebrow small-eyebrow">@category.Key</span>
                        <h2>@category.Title</h2>
                    </div>
                    <span class="count-pill">@category.TemplateCount 套模板</span>
                </div>
                <p>@category.Description</p>
                <div class="stats-row">
                    <span>已通过 @category.ApprovedCount</span>
                    <span>待审核 @category.PendingCount</span>
                </div>
                <div class="tag-row">
                    @foreach (var tag in category.HighlightTags)
                    {
                        <span class="tag-chip">@tag</span>
                    }
                </div>
            </article>
        }
    </section>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <p class="error-text">@_error</p>
}

@code {
    private IReadOnlyList<AdminCategorySummaryDto> _categories = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _categories = await TemplateService.GetAdminCategoriesAsync();
        }
        catch (Exception exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
