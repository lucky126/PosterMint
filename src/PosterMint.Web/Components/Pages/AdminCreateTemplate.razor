@page "/admin/templates/new"
@using PosterMint.Application.Configs
@using PosterMint.Application.Templates
@using PosterMint.Domain.Enums
@inject IConfigService ConfigService
@inject ITemplateService TemplateService
@inject NavigationManager NavigationManager

<PageTitle>新建模板</PageTitle>

<section class="hero create-hero">
    <div class="hero-copy">
        <p class="eyebrow">Mall Creation</p>
        <h1>先说你要做什么模板，再进入对话制作</h1>
        <p class="summary">
            商场运营侧不应该先操作结构和 JSON。先选模板场景，再用一句话告诉系统目标，
            然后进入对话式模板编辑器，背景、价格区、二维码区和卖点区都通过对话生成。
        </p>
    </div>
</section>

<section class="scene-grid">
    @foreach (var scene in _scenes)
    {
        <button class="scene-card @GetSceneCardClass(scene.Scene)" @onclick="() => _selectedScene = scene.Scene">
            <span class="scene-card__icon">@scene.Icon</span>
            <strong>@scene.Title</strong>
            <span>@scene.Description</span>
        </button>
    }
</section>

<section class="create-workbench">
    <div class="create-panel">
        <h2>一句话描述模板目标</h2>
        <textarea @bind="_goal" placeholder="例如：做一张火锅店周末促销模板，背景要喜庆红，底部留二维码区，中间要突出套餐价格"></textarea>
        <p class="helper-text">不用写设计术语，直接说你想做成什么样。</p>
    </div>

    <div class="create-panel">
        <h2>先生成一个模板草稿，再进入对话编辑</h2>
        <p class="helper-text">
            这一步会先创建一张可编辑模板。进入编辑器后，你可以继续说：
            “背景改成喜庆红”“加二维码区在右下角”“价格区更醒目”“加三个卖点标签”。
        </p>
        <button class="action-button action-button--large" @onclick="CreateAsync" disabled="@_creating">
            @(_creating ? "正在创建模板…" : "开始做模板")
        </button>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <p class="error-text">@_error</p>
}

@code {
    private readonly IReadOnlyList<AdminSceneOption> _scenes =
    [
        new(TemplateSceneType.SingleDish, "🍲", "单菜品促销模板", "适合主推单品、活动价和二维码区"),
        new(TemplateSceneType.Menu, "📋", "菜单模板", "适合多菜品、多价格和套餐网格"),
        new(TemplateSceneType.StorePromo, "🏮", "门店宣传模板", "适合门头图、简介、地址、电话和二维码"),
        new(TemplateSceneType.Festival, "🎊", "节庆活动模板", "适合节假日、节气和专题促销")
    ];

    private TemplateSceneType _selectedScene = TemplateSceneType.SingleDish;
    private string _goal = "做一张火锅店周末促销模板，背景要喜庆红，底部留二维码区，中间突出活动价";
    private bool _creating;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var status = await ConfigService.GetAiConfigurationStatusAsync();
        if (!status.IsReady)
        {
            NavigationManager.NavigateTo("/setup/ai?returnUrl=%2Fadmin%2Ftemplates%2Fnew");
        }
    }

    private async Task CreateAsync()
    {
        _creating = true;
        _error = null;

        try
        {
            var request = StarterTemplateFactory.Create(_selectedScene, _goal);
            var created = await TemplateService.CreateAsync(request);
            NavigationManager.NavigateTo($"/admin/templates/{created.Id}");
        }
        catch (Exception exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _creating = false;
        }
    }

    private string GetSceneCardClass(TemplateSceneType scene) => scene == _selectedScene ? "is-active" : string.Empty;

    private sealed record AdminSceneOption(TemplateSceneType Scene, string Icon, string Title, string Description);
}
