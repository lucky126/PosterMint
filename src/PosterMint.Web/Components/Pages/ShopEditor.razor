@page "/"
@page "/shop/sessions/{SessionKey}"
@using PosterMint.Application.AI
@using PosterMint.Application.Configs
@using PosterMint.Application.Sessions
@using PosterMint.Application.Rendering
@using Microsoft.AspNetCore.Components.Forms
@inject ISessionService SessionService
@inject IRenderService RenderService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>AI 海报编辑</PageTitle>

<div class="chat-designer-shell">
    <div class="preview-panel">
        <div class="panel-header">
            <span class="eyebrow">PREVIEW</span>
            <h2>海报实时预览</h2>
            @if (_session != null)
            {
                <p class="scene-label">场景：@GetSceneTitle(_session.Scene)</p>
            }
        </div>

        <div class="poster-stage">
            @if (_loading)
            {
                <div class="loading-placeholder">
                    <div class="spinner"></div>
                    <p>正在加载海报…</p>
                </div>
            }
            else if (_session != null)
            {
                <div class="poster-scale">
                    @((MarkupString)_previewMarkup)
                </div>
            }
            else
            {
                <div class="loading-placeholder">
                    <p>👈 先在右侧选择海报类型，开始对话创作</p>
                </div>
            }
        </div>

        @if (_session != null)
        {
            <div class="quick-actions-row">
                <span class="version-tag">版本 v.@_session.Versions.Count</span>
                <button class="ghost-button" @onclick="ResetTemplate">↺ 重置</button>
                <button class="ghost-button" @onclick="ExportHtml">📄 导出 HTML</button>
                <button class="ghost-button" @onclick="ExportSvg">📥 导出 SVG</button>
            </div>
        }
    </div>

    <div class="conversation-panel">
        <div class="panel-header">
            <span class="eyebrow">AI ASSISTANT</span>
            <h2>对话设计助手</h2>
            <p class="hint">用自然语言告诉我你想要的效果，我来帮你调整</p>
        </div>

        <div class="chat-log-container">
            <div class="chat-log">
                @if (_session == null)
                {
                    <div class="chat-bubble assistant welcome">
                        <div class="avatar">🤖</div>
                        <div class="message-content">
                            <p><strong>你好！想做哪种海报？</strong></p>
                            <p>选一个类型，我们直接开始对话创作：</p>
                            <div class="scene-picker">
                                <button class="scene-option" disabled="@_creating" @onclick="@(() => SelectSceneAsync("single-dish"))">
                                    <span class="scene-emoji">🍲</span>
                                    <span class="scene-name">单菜品海报</span>
                                    <span class="scene-desc">主打菜、促销单品</span>
                                </button>
                                <button class="scene-option" disabled="@_creating" @onclick="@(() => SelectSceneAsync("menu"))">
                                    <span class="scene-emoji">📋</span>
                                    <span class="scene-name">菜单海报</span>
                                    <span class="scene-desc">多菜品、套餐菜单</span>
                                </button>
                                <button class="scene-option" disabled="@_creating" @onclick="@(() => SelectSceneAsync("store-promo"))">
                                    <span class="scene-emoji">🏪</span>
                                    <span class="scene-name">门店宣传</span>
                                    <span class="scene-desc">品牌、新店开业</span>
                                </button>
                            </div>
                            @if (_creating)
                            {
                                <p class="scene-creating"><span class="spinner-sm"></span> 正在创建会话…</p>
                            }
                        </div>
                    </div>
                }
                else if (_session.Messages.Count == 0)
                {
                    <div class="chat-bubble assistant welcome">
                        <div class="avatar">🤖</div>
                        <div class="message-content">
                            <p><strong>你好！我是你的海报设计助手</strong></p>
                            <p>我可以帮你：</p>
                            <ul>
                                <li>修改店铺名称、菜品名称</li>
                                <li>调整价格、促销信息</li>
                                <li>替换菜品图片、二维码</li>
                                <li>更改配色方案、字体风格</li>
                                <li>调整布局、元素位置和大小</li>
                            </ul>
                            <p>现在试试对我说：<em>"把店名改成老街小厨，价格改成 88 元</em></p>
                        </div>
                    </div>
                }
                else
                {
                    @foreach (var item in _session.Messages)
                    {
                        <div class="chat-bubble @(item.Role)">
                            <div class="avatar">@(item.Role == "user" ? "👤" : "🤖")</div>
                            <div class="message-content">
                                @if (item.Type == "edit-summary")
                                {
                                    <div class="system-label">📝 已完成</div>
                                }
                                <p>@item.Text</p>
                                @if (item.Changes != null && item.Changes.Count > 0)
                                {
                                    <div class="changes-list">
                                        @foreach (var change in item.Changes)
                                        {
                                            <span class="change-tag">@change</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }

                @if (_isProcessing)
                {
                    <div class="chat-bubble assistant thinking">
                        <div class="avatar">🤖</div>
                        <div class="message-content">
                            <span>正在理解你的需求，生成海报修改中</span>
                            <span class="thinking-dots">
                                <span></span><span></span><span></span>
                            </span>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="suggestion-chips" style="display: @(_session != null && _showSuggestions ? "flex" : "none")">
            <button class="chip-button" @onclick="@(() => ApplySuggestion("把店名改成XX餐馆"))">改店名</button>
            <button class="chip-button" @onclick="@(() => ApplySuggestion("把价格改成99.9元"))">改价格</button>
            <button class="chip-button" @onclick="@(() => ApplySuggestion("换个喜庆红色背景"))">换配色</button>
            <button class="chip-button" @onclick="@(() => ApplySuggestion("标题字体加大"))">加大字体</button>
            <button class="chip-button" @onclick="@(() => ApplySuggestion("菜品图片换成红烧肉"))">换菜品图</button>
        </div>

        <div class="compose-area">
            @if (_pendingAssets.Count > 0)
            {
                <div class="pending-assets">
                    @foreach (var asset in _pendingAssets)
                    {
                        <div class="pending-thumb">
                            <img src="@asset.DataUrl" alt="@asset.Name" />
                            <button type="button" class="thumb-remove" @onclick="@(() => RemoveAsset(asset))">×</button>
                        </div>
                    }
                </div>
            }
            <textarea
                @bind="_chatMessage"
                placeholder="@(_session == null ? "请先在上方选择海报类型…" : "描述你想要的海报效果…（例如：把店名改成老街小厨，价格改成 88 元，让背景更喜庆一点）")"
                @onkeydown="HandleKeyDown"
                disabled="@(_isProcessing || _session == null)">
            </textarea>
            <div class="compose-actions">
                <label class="upload-button @(_isProcessing || _session == null ? "is-disabled" : string.Empty)">
                    📎 上传图片
                    <InputFile OnChange="OnUploadChanged" accept="image/*" multiple disabled="@(_isProcessing || _session == null)" hidden />
                </label>
                <button class="send-button" @onclick="SendChatAsync" disabled="@(_isProcessing || _session == null || (string.IsNullOrWhiteSpace(_chatMessage) && _pendingAssets.Count == 0))">
                    @(_isProcessing ? "处理中…" : "发送消息")
                </button>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="error-toast">
        <span>❌ @_error</span>
        <button @onclick="() => _error = null">×</button>
    </div>
}

@code {
    [Parameter]
    public string SessionKey { get; set; } = string.Empty;

    private PosterSessionDto? _session;
    private bool _loading = true;
    private bool _isProcessing;
    private bool _creating;
    private string _chatMessage = string.Empty;
    private string _previewMarkup = string.Empty;
    private string? _error;
    private bool _showSuggestions = true;
    private readonly List<SessionAssetDto> _pendingAssets = new();

    private const long MaxUploadBytes = 8 * 1024 * 1024;

    protected override async Task OnInitializedAsync()
    {
        await LoadSessionAsync();
    }

    private async Task LoadSessionAsync()
    {
        _loading = true;
        try
        {
            if (string.IsNullOrWhiteSpace(SessionKey))
            {
                // 首页模式：还没选场景，不加载会话，显示场景选择
                _session = null;
                return;
            }

            _session = await SessionService.GetAsync(SessionKey);
            RebuildPreview();
        }
        catch (Exception ex)
        {
            _error = $"加载失败: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SelectSceneAsync(string scene)
    {
        if (_creating || _isProcessing) return;

        _creating = true;
        _error = null;
        StateHasChanged();

        try
        {
            var session = await SessionService.BootstrapAsync(new BootstrapSessionRequest
            {
                Scene = scene,
                Goal = GetGoalForScene(scene)
            });

            _session = session;
            SessionKey = session.SessionKey;
            RebuildPreview();

            // 就地更新地址栏，不刷新页面
            NavigationManager.NavigateTo($"/shop/sessions/{session.SessionKey}", forceLoad: false, replace: true);
        }
        catch (Exception ex)
        {
            _error = $"创建失败: {ex.Message}";
        }
        finally
        {
            _creating = false;
            StateHasChanged();
        }
    }

    private static string GetGoalForScene(string scene)
        => scene switch
        {
            "single-dish" => "制作一张单菜品促销海报，包含菜品名称、价格、促销信息",
            "menu" => "制作一张菜单海报，展示多个菜品和价格",
            "store-promo" => "制作一张门店宣传海报，包含店名、特色、联系方式",
            _ => "制作一张餐饮海报"
        };

    private void RebuildPreview()
    {
        if (_session == null) return;
        // 内联渲染海报（固定 1080×1920），由 OnAfterRenderAsync 调 JS 等比缩放
        _previewMarkup = RenderService.RenderPosterHtml(_session);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // 每次渲染后都重新缩放海报，保证预览比例正确
        if (_session != null)
        {
            try
            {
                await JS.InvokeVoidAsync("fitPoster");
            }
            catch
            {
                // 首次预渲染阶段 JS 尚不可用，忽略；交互渲染阶段会再次调用
            }
        }
    }

    private async Task SendChatAsync()
    {
        if (_session == null || (string.IsNullOrWhiteSpace(_chatMessage) && _pendingAssets.Count == 0) || _isProcessing) return;

        _isProcessing = true;
        _showSuggestions = false;
        _error = null;
        StateHasChanged();

        try
        {
            var result = await SessionService.ApplyChatAsync(SessionKey, new ApplySessionChatRequest
            {
                Message = _chatMessage.Trim(),
                Assets = _pendingAssets.ToList()
            });

            _session = result.Session;
            _chatMessage = string.Empty;
            _pendingAssets.Clear();
            RebuildPreview();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            return SendChatAsync();
        }
        return Task.CompletedTask;
    }

    private void ApplySuggestion(string suggestion)
    {
        _chatMessage = suggestion;
        _ = SendChatAsync();
    }

    private async Task OnUploadChanged(InputFileChangeEventArgs e)
    {
        _error = null;
        foreach (var file in e.GetMultipleFiles(maximumFileCount: 5))
        {
            try
            {
                if (file.Size > MaxUploadBytes)
                {
                    _error = $"图片 {file.Name} 超过 8MB，已跳过";
                    continue;
                }

                using var stream = file.OpenReadStream(MaxUploadBytes);
                using var memory = new MemoryStream();
                await stream.CopyToAsync(memory);
                var base64 = Convert.ToBase64String(memory.ToArray());
                var contentType = string.IsNullOrWhiteSpace(file.ContentType) ? "image/png" : file.ContentType;
                _pendingAssets.Add(new SessionAssetDto("referenceImage", file.Name, $"data:{contentType};base64,{base64}"));
            }
            catch (Exception ex)
            {
                _error = $"图片 {file.Name} 上传失败：{ex.Message}";
            }
        }
    }

    private void RemoveAsset(SessionAssetDto asset)
    {
        _pendingAssets.Remove(asset);
    }

    private void ResetTemplate()
    {
        _error = "重置功能开发中…";
    }

    private void ExportHtml()
    {
        _error = "HTML 导出开发中…";
    }

    private void ExportSvg()
    {
        _error = "SVG 导出开发中…";
    }

    private static string GetSceneTitle(string scene)
        => scene switch
        {
            "menu" => "菜单海报",
            "store-promo" => "门店宣传",
            _ => "单菜品促销"
        };
}
