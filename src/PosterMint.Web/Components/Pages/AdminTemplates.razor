@page "/admin/templates"
@using PosterMint.Application.Templates
@using PosterMint.Domain.Enums
@inject ITemplateService TemplateService
@inject NavigationManager NavigationManager

<PageTitle>后台模板库</PageTitle>

<section class="hero admin-hero">
    <p class="eyebrow">Template Library</p>
    <h1>商场模板库</h1>
    <p class="summary">
        模板库展示的是商场当前可生产、待审核和已上架的模板资产。运营侧应先产出模板，再把可用模板分发给商铺。
    </p>
</section>

<section class="toolbar">
    <div class="toolbar__filters">
        <label>
            状态
            <select @bind="_statusFilter">
                <option value="all">全部</option>
                <option value="Draft">草稿</option>
                <option value="Pending">待审核</option>
                <option value="Approved">已通过</option>
                <option value="Rejected">已驳回</option>
            </select>
        </label>
        <label>
            场景
            <select @bind="_sceneFilter">
                <option value="all">全部</option>
                <option value="SingleDish">单菜品</option>
                <option value="Menu">菜单</option>
                <option value="StorePromo">门店宣传</option>
                <option value="Festival">节庆活动</option>
            </select>
        </label>
    </div>

    <div class="toolbar__actions">
        <button class="action-button action-button--ghost" @onclick="() => CreateStarterAsync(TemplateSceneType.Menu)">新建菜单模板</button>
        <button class="action-button" @onclick="() => CreateStarterAsync(TemplateSceneType.SingleDish)">新建单品模板</button>
    </div>
</section>

@if (_loading)
{
    <p>正在加载模板库…</p>
}
else
{
    <section class="template-grid admin-template-grid">
        @foreach (var template in FilteredTemplates)
        {
            <article class="template-card">
                <div class="template-card__meta">
                    <span class="scene-pill">@GetSceneText(template.Scene)</span>
                    <span class="status-pill @GetStatusClass(template.Status)">@GetStatusText(template.Status)</span>
                </div>
                <h2>@template.Name</h2>
                <p>@template.Description</p>
                <div class="tag-row">
                    @foreach (var tag in template.Tags.Take(4))
                    {
                        <span class="tag-chip">@tag.TagValue</span>
                    }
                </div>
                <div class="template-card__footer">
                    <span>更新于 @template.UpdatedAt.ToLocalTime().ToString("MM-dd HH:mm")</span>
                    <button class="action-button" @onclick="() => OpenTemplate(template.Id)">进入编辑</button>
                </div>
            </article>
        }
    </section>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <p class="error-text">@_error</p>
}

@code {
    private IReadOnlyList<TemplateSummaryDto> _templates = [];
    private bool _loading = true;
    private string? _error;
    private string _statusFilter = "all";
    private string _sceneFilter = "all";

    private IEnumerable<TemplateSummaryDto> FilteredTemplates =>
        _templates.Where(template =>
            (_statusFilter == "all" || string.Equals(template.Status.ToString(), _statusFilter, StringComparison.OrdinalIgnoreCase)) &&
            (_sceneFilter == "all" || string.Equals(template.Scene.ToString(), _sceneFilter, StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _templates = await TemplateService.ListAsync();
        }
        catch (Exception exception)
        {
            _error = exception.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task CreateStarterAsync(TemplateSceneType scene)
    {
        try
        {
            var starter = StarterTemplateFactory.Create(scene);
            var created = await TemplateService.CreateAsync(starter);
            NavigationManager.NavigateTo($"/admin/templates/{created.Id}");
        }
        catch (Exception exception)
        {
            _error = exception.Message;
        }
    }

    private void OpenTemplate(int id) => NavigationManager.NavigateTo($"/admin/templates/{id}");

    private static string GetSceneText(TemplateSceneType scene) => scene switch
    {
        TemplateSceneType.Menu => "菜单",
        TemplateSceneType.StorePromo => "门店宣传",
        TemplateSceneType.Festival => "节庆活动",
        TemplateSceneType.Custom => "自定义",
        _ => "单菜品"
    };

    private static string GetStatusText(TemplateStatus status) => status switch
    {
        TemplateStatus.Pending => "待审核",
        TemplateStatus.Approved => "已通过",
        TemplateStatus.Rejected => "已驳回",
        TemplateStatus.Archived => "已归档",
        _ => "草稿"
    };

    private static string GetStatusClass(TemplateStatus status) => status switch
    {
        TemplateStatus.Pending => "is-pending",
        TemplateStatus.Approved => "is-approved",
        TemplateStatus.Rejected => "is-rejected",
        _ => "is-draft"
    };
}
